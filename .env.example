# Copy these into `.env.local` for local development
# and into your Vercel project settings for deployment.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Web push foundation
# Public key is used by the browser for PushManager.subscribe(...).
# The runtime push-config route can serve either WEB_PUSH_VAPID_PUBLIC_KEY
# or NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY to the client.
WEB_PUSH_VAPID_PUBLIC_KEY=your-web-push-vapid-public-key
NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=your-web-push-vapid-public-key
# Private key is used server-side for signed Web Push delivery
WEB_PUSH_VAPID_PRIVATE_KEY=your-web-push-vapid-private-key
# Optional contact subject for VAPID metadata
WEB_PUSH_VAPID_SUBJECT=mailto:notifications@example.com
